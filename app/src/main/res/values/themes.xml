<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.ClubDeportivo" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.ClubDeportivo" parent="Base.Theme.ClubDeportivo" />

    <!--Style del boton que es usado a lo largo del proyecto-->
    <style name="LoginButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/red_app</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">30dp</item>
        <item name="rippleColor">@android:color/white</item>
    </style>

    <!-- Estilo personalizado para el menú lateral -->
    <style name="MenuLateralDialog" parent="Theme.AppCompat.Light.Dialog">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.InputMethod</item>
    </style>

    <!-- Estilo personalizado para el botón de imagen circular  -->
    <style name="CircleImageView">
        <item name="cornerSize">50%</item>
    </style>


</resources>