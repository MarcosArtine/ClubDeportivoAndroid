<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp"
    android:background="?attr/selectableItemBackground">

    <TextView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:text="P"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@color/red_app"
        android:layout_marginEnd="12dp"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvFechaPago"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="dd/MM/yyyy"
            android:textSize="11sp"
            android:textColor="#9E9E9E"/>

        <TextView
            android:id="@+id/tvNombrePago"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre Apellido"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/red_app"/>

        <TextView
            android:id="@+id/tvTipoPago"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cuota"
            android:textSize="11sp"
            android:textColor="#9E9E9E"/>

    </LinearLayout>

    <TextView
        android:id="@+id/tvMontoPago"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="$0"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginEnd="8dp"/>

    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_comprobante"
        android:contentDescription="Comprobante"/>

</LinearLayout>
